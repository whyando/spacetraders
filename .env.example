RUST_LOG=info,st=debug
RUST_LOG_STYLE=always
RUST_BACKTRACE=0

POSTGRES_URI=postgres://postgres:<password>@<host>:5432/spacetraders
POSTGRES_SCHEMA=live_{RESET_DATE}

SPACETRADERS_API_URL=https://api.spacetraders.io/v2
SPACETRADERS_ACCOUNT_TOKEN=eyJ...
AGENT_CALLSIGN=BADGER
AGENT_FACTION=COSMIC

# Web API port (read-only JSON consumed by the dashboard SPA). Default 8080.
# WEB_PORT=8080

# debug flags:
# JOB_ID_FILTER=^jumpgate_probe
# OVERRIDE_CONSTRUCTION_SUPPLY_CHECK=1
# SCRAP_ALL_SHIPS=1
# SCRAP_UNASSIGNED=1
# ERA_OVERRIDE=InterSystem2
# DEBUG_DISABLE_TRADING_TASKS=1
# DEBUG_DISABLE_CONTRACT_TASKS=1

# See the README "Development" section for running locally against the dev DB.

